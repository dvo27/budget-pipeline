  create view "budget"."main_intermediate"."int_transactions_enriched__dbt_tmp" as (
    -- This model reads from the staging model and enriches each transaction with budget context


SELECT 
    *,
    CASE
        WHEN is_income = TRUE THEN 'income'
        ELSE 'uncategorized'
