  create view "budget"."main_marts"."fct_monthly_spending__dbt_tmp" as (
    -- aggregates transactions into monthly summaries by category


SELECT
    transaction_month,
    category,
    SUM(amount_abs) AS total_spent,
    COUNT(*) AS transaction_count
FROM "budget"."main_intermediate"."int_transactions_enriched"
WHERE is_income = FALSE AND category NOT IN ('rent', 'reimbursement') AND NOT (category = 'reimbursement' AND amount_abs > 1000)
GROUP BY transaction_month, category
  );

